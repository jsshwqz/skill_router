      "input": "搜索 Rust 编程语言",
      "output": "{\"status\":\"success\",\"skill\":\"google_search\",\"results\":[...]}"
    }
  ],
  "config_schema": {
    "count": 5,
    "api_key_env": "GOOGLE_API_KEY"
  },
  "metadata": {
    "author": "Gemini CLI",
    "created_at": "2026-03-12",
    "last_updated": "2026-03-12",
    "type": "network",
    "lang": "rust"
  }
}
