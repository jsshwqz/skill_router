{
  "name": "synth_skillsynthesize",
  "version": "0.1.0",
  "description": "技能合成技能 - Rust 实现，用于动态生成新技能",
  "capabilities": ["skill_generation", "code_synthesis"],
  "permissions": {
    "network": false,
    "filesystem_read": false,
    "filesystem_write": true,
    "process_exec": false
  },
  "entrypoint": "main.rs",
  "dependencies": ["serde", "serde_json"],
  "examples": [
    {
      "input": "生成一个新技能",
      "output": "{\"status\":\"success\",\"skill\":\"synth_skillsynthesize\",\"skill_info\":{...},\"code\":\"...\"}"
    }
  ],
  "config_schema": {
    "skills_dir": "skills"
  },
  "metadata": {
    "author": "Gemini CLI",
    "created_at": "2026-03-12",
    "last_updated": "2026-03-12",
    "type": "synthesis",
    "lang": "rust"
  }
}
