    "network": false,
    "filesystem_read": false,
    "filesystem_write": false,
    "process_exec": false
  },
  "entrypoint": "main.rs",
  "dependencies": ["serde", "serde_json"],
  "examples": [
    {
      "input": "生成文本摘要",
      "output": "{\"status\":\"success\",\"skill\":\"synth_textsummarize\",\"summary\":\"...\",\"original_length\":123,\"summary_length\":50}"
    }
  ],
  "config_schema": {
    "max_length": 100
  },
  "metadata": {
    "author": "Gemini CLI",
    "created_at": "2026-03-12",
    "last_updated": "2026-03-12",
    "type": "synthesis",
    "lang": "rust"
  }
}
