# Aion Forge — 环境变量配置示例
# 复制此文件为 .env 并根据实际情况填写值
# cp .env.example .env

# ── AI 推理后端 (Ollama / OpenAI / Google AI) ──────────────────────────────

# Ollama（默认，本地部署）
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=qwen2.5:7b

# OpenAI（若使用 OpenAI，取消以下注释）
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google AI（若使用 Gemini，取消以下注释）
# GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GOOGLE_AI_API_KEY=AIza...
# GOOGLE_AI_MODEL=gemini-2.0-flash

# ── 搜索服务 ────────────────────────────────────────────────────────────────

# SerpAPI Key（用于 web_search / discovery_search 能力）
# 获取地址：https://serpapi.com/
SERPAPI_KEY=

# ── 安全策略 ─────────────────────────────────────────────────────────────────

# AI 安全审查失败时的策略：open（放行）| closed（拒绝，推荐生产环境使用）
AI_SECURITY_FAIL_POLICY=open

# ── 分布式 / 多 Agent（Phase 1+，可选）───────────────────────────────────────

# NATS 服务地址（用于多节点通信，留空则使用进程内消息总线）
# NATS_URL=nats://localhost:4222

# 当前节点角色：orchestrator | planner | executor | specialist | reviewer | memory_keeper
# NODE_ROLE=orchestrator

# 当前节点专属能力（specialist 角色时使用，逗号分隔）
# NODE_CAPABILITIES=text_summarize,text_classify,text_extract

# ── HTTP API Server (aion-server) ──────────────────────────────────────────

# 工作区路径（默认使用当前目录）
# AION_WORKSPACE=/path/to/workspace

# 监听地址和端口
AION_HOST=0.0.0.0
AION_PORT=3000

# ── 日志 ────────────────────────────────────────────────────────────────────

# 日志级别：error | warn | info | debug | trace
RUST_LOG=aion_server=info,aion_router=info,aion_intel=info,aion_memory=info
