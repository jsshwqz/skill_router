{
  "name": "exa_search",
  "version": "0.1.0",
  "description": "Exa Search 技能 - 免费AI语义搜索，专为LLM优化的搜索结果",
  "capabilities": ["ai_search", "semantic_search", "information_retrieval"],
  "permissions": {
    "network": true,
    "filesystem_read": false,
    "filesystem_write": false,
    "process_exec": false
  },
  "entrypoint": "main.rs",
  "dependencies": ["reqwest", "serde", "tokio"],
  "examples": [
    {
      "input": "Rust programming best practices",
      "output": "{"status":"success","skill":"exa_search","results":[{"title":"...","url":"...","text":"..."}]}"
    }
  ],
  "config_schema": {
    "use_autoprompt": true,
    "num_results": 5,
    "timeout_seconds": 30
  },
  "metadata": {
    "author": "Gemini CLI",
    "created_at": "2026-03-13",
    "last_updated": "2026-03-13",
    "type": "network",
    "lang": "rust"
  }
}