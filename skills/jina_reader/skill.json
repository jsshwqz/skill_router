{
  "name": "jina_reader",
  "version": "0.1.0",
  "description": "Jina Reader 技能 - 免费网页内容提取，将任意网页转换为干净的Markdown格式",
  "capabilities": ["web_reader", "content_extraction", "markdown_conversion"],
  "permissions": {
    "network": true,
    "filesystem_read": false,
    "filesystem_write": false,
    "process_exec": false
  },
  "entrypoint": "main.rs",
  "dependencies": ["reqwest", "serde", "tokio"],
  "examples": [
    {
      "input": "https://example.com",
      "output": "{"status":"success","skill":"jina_reader","content":"# Example Domain..."}"
    }
  ],
  "config_schema": {
    "timeout_seconds": 30
  },
  "metadata": {
    "author": "Gemini CLI",
    "created_at": "2026-03-13",
    "last_updated": "2026-03-13",
    "type": "network",
    "lang": "rust"
  }
}